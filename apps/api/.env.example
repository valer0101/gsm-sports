# App
NODE_ENV=development

# First admin (created automatically on startup if not exists)
ADMIN_EMAIL=admin@gsm.com
ADMIN_PASSWORD=change-me-in-production
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://gsm_user:gsm_dev_password@localhost:5432/gsm_sports

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Check-in QR signing (see apps/api/src/entries/check-in.service.ts).
# Required in production; if unset in dev, derived from JWT_ACCESS_SECRET.
# JWT_CHECKIN_SECRET=your-checkin-secret-min-32-chars

# Telegram notifications (Phase 2.4). Unset = stub mode: messages are
# logged, not sent. Get a token from @BotFather.
# TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFGGHHIIJJKKLLMMNNOOPPQQR
# TELEGRAM_BOT_USERNAME=your_bot_name        # without leading @, used for deep-links
