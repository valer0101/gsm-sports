# App
NODE_ENV=development

# First admin (created automatically on startup if not exists)
ADMIN_EMAIL=admin@gsm.com
ADMIN_PASSWORD=change-me-in-production
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://gsm_user:gsm_dev_password@localhost:5432/gsm_sports

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Check-in QR signing (see apps/api/src/entries/check-in.service.ts).
# Required in production; if unset in dev, derived from JWT_ACCESS_SECRET.
# JWT_CHECKIN_SECRET=your-checkin-secret-min-32-chars

# Google OAuth (see apps/api/src/auth/google.strategy.ts +
# docs/07-SECURITY-AND-AUTH.md §2). Both client id + secret must be
# set for the /v1/auth/google* endpoints to register; otherwise the
# app boots without Google sign-in and logs a warning.
# GOOGLE_CLIENT_ID=<from Google Cloud Console → APIs & Services → Credentials>
# GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
# GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
# GOOGLE_SUCCESS_REDIRECT=http://localhost:3000/auth/google/callback

# Signs the OAuth `state` JWT (CSRF + post-login redirect carry-over).
# Optional — falls back to JWT_ACCESS_SECRET in dev. In prod, set a
# dedicated secret so a leak of one doesn't compromise the other.
# OAUTH_STATE_SECRET=your-oauth-state-secret-min-32-chars

# Telegram notifications (Phase 2.4). Unset = stub mode: messages are
# logged, not sent. Get a token from @BotFather.
# TELEGRAM_BOT_TOKEN=<your-bot-token-from-BotFather>
TELEGRAM_BOT_USERNAME=gsm_armwrestling_bot
# Polling vs webhook: `polling` is dev-friendly (no public URL needed);
# `webhook` is the prod shape (needs TELEGRAM_WEBHOOK_URL set).
# TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://api.example.com/v1/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random-32-char-string-for-telegram-to-echo-back
